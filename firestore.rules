rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ SECURITY UPGRADE: Allow all authenticated users 
    // This fixes the "Permission Denied" error for your mobile app
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow scans for clarity
    match /users/{userId}/scans/{scanId} {
      allow read, write: if request.auth != null;
    }
    
    
    match /history/{id} { allow read, write: if request.auth != null; }
    match /scan_logs/{id} { allow read, write: if request.auth != null; }
    match /daily_app_metrics/{id} { allow read, write: if request.auth != null; }
    
    // Top-level goals collection - users can only access their own goals
    match /goals/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Top-level strava_stats collection - users can only access their own stats
    match /strava_stats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
